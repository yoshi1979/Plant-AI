# App
NEXT_PUBLIC_APP_NAME=Plant Health Assistant
APP_BASE_URL=http://localhost:3000
ADMIN_API_KEY=change-me

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/plant_agent
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=plant-images

# WhatsApp (choose one provider)
WHATSAPP_PROVIDER=meta
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-meta-app-secret
WHATSAPP_API_VERSION=v22.0

# Twilio alternative
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AI / Vision / Search
AI_PROVIDER=openai
AI_API_KEY=your-key
AI_VISION_MODEL=gpt-4.1-mini
AI_TEXT_MODEL=gpt-4.1-mini
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=your-search-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional storage / observability
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
LOG_LEVEL=info
